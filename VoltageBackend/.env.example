# Nusxa oling: cp .env.example .env  va qiymatlarni to'ldiring
DATABASE_URL=postgresql+psycopg://voltage_user:CHANGEME@localhost:5432/voltage
REDIS_URL=redis://localhost:6379/1

# Maxfiy kalit — ALBATTA almashtiring:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGEME-generate-a-random-64-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Bootstrap admin — kuchli (≥12 belgi) parol qo'ying, "admin123" kabi emas
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGEME-use-a-strong-password
ADMIN_EMAIL=admin@example.com

# Tarmoq
TCP_PORT=5001
HTTP_PORT=5000
CORS_ORIGINS=*

# Ixtiyoriy: TCP ingest tokeni (qurilma spoofing'iga qarshi).
# O'rnatilsa, qurilma "TOKEN:id:value" yuborishi kerak (Arduino'da ham yozing).
# Bo'sh qoldirilsa — eski "id:value" formati ishlaydi.
# INGEST_TOKEN=
